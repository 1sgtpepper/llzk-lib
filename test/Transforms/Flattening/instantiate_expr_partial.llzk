  }
}

// CHECK-LABEL: poly.template @"InnerFunc_5_\1A" {
// CHECK:         poly.param @M : index
// CHECK:         poly.expr @TwiceM {
// CHECK:           poly.read_const @M : index
// CHECK:         poly.expr @NPlusM {
// CHECK:           arith.constant 5 : index
// CHECK:           poly.read_const @M : index
// CHECK-NOT:       poly.read_const @N
// CHECK:         function.def @value
// CHECK:           poly.read_const @NPlusM : index
// -----

module attributes {llzk.lang} {
  poly.template @Inner {
    poly.param @Num
    poly.param @Ty : !poly.tvar<@Ty>
    poly.param @M
    poly.expr @Sum {
      %m = poly.read_const @M : !felt.type<"bn128">
      %num = poly.read_const @Num : !poly.tvar<@Ty>
      %cast = poly.unifiable_cast %num : (!poly.tvar<@Ty>) -> !felt.type<"bn128">
      %sum = felt.add %m, %cast : !felt.type<"bn128">, !felt.type<"bn128">
      poly.yield %sum : !felt.type<"bn128">
    }
    struct.def @Value {
      function.def @compute() -> !struct.type<@Inner::@Value<[@Num, @Ty, @M]>> {
        %sum = poly.read_const @Sum : !felt.type<"bn128">
        %self = struct.new : <@Inner::@Value<[@Num, @Ty, @M]>>
        function.return %self : !struct.type<@Inner::@Value<[@Num, @Ty, @M]>>
      }
      function.def @constrain(%self: !struct.type<@Inner::@Value<[@Num, @Ty, @M]>>) {
        function.return
      }
    }
  }

  poly.template @Outer {
    poly.param @M
    struct.def @Wrapper {
      struct.member @value : !struct.type<@Inner::@Value<[35, !felt.type<"bn128">, @M]>>
      function.def @compute() -> !struct.type<@Outer::@Wrapper<[@M]>> {
        %self = struct.new : <@Outer::@Wrapper<[@M]>>
        function.return %self : !struct.type<@Outer::@Wrapper<[@M]>>
      }
      function.def @constrain(%self: !struct.type<@Outer::@Wrapper<[@M]>>) {
        function.return
      }
    }
  }
}

// CHECK-LABEL: poly.template @"Inner_35_f_\1A" {

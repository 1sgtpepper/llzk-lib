// CHECK:           poly.unifiable_cast {{.*}} : (!felt.type<"bn128">) -> !felt.type<"bn128">
// CHECK-NOT:       !poly.tvar<@Ty>
// CHECK:         struct.def @Value {
// -----

module attributes {llzk.lang} {
  poly.template @Inner {
    poly.param @Num
    poly.param @Ty : !poly.tvar<@Ty>
    poly.param @M
    poly.expr @Sum {
      %m = poly.read_const @M : !felt.type<"bn128">
      %num = poly.read_const @Num : !poly.tvar<@Ty>
      %cast = poly.unifiable_cast %num : (!poly.tvar<@Ty>) -> !felt.type<"bn128">
      %sum = felt.add %m, %cast : !felt.type<"bn128">, !felt.type<"bn128">
      poly.yield %sum : !felt.type<"bn128">
    }
    function.def @value() -> !felt.type<"bn128"> {
      %sum = poly.read_const @Sum : !felt.type<"bn128">
      function.return %sum : !felt.type<"bn128">
    }
  }

  poly.template @Outer {
    poly.param @M
    function.def @value() -> !felt.type<"bn128"> {
      %sum = function.call @Inner::@value<[#felt<const 35 : !felt.type<"bn128">>, !felt.type<"bn128">, @M]>()
        : () -> !felt.type<"bn128">
      function.return %sum : !felt.type<"bn128">
    }
  }
}

// CHECK-LABEL: poly.template @"Inner_f<35:5:bn128>_f_\1A" {
// CHECK:         poly.param @M
// CHECK:         poly.expr @Sum {
// CHECK:           felt.const 35 : <"bn128">
// CHECK:           poly.read_const @M : !felt.type<"bn128">
// CHECK:           poly.unifiable_cast {{.*}} : (!felt.type<"bn128">) -> !felt.type<"bn128">
// CHECK-NOT:       !poly.tvar<@Ty>
// CHECK:         function.def @value
// -----

module attributes {llzk.lang} {
  poly.template @Inner {
    poly.param @Num
    poly.param @Ty : !poly.tvar<@Ty>
    poly.param @M
    poly.expr @Chosen {
      %num = poly.read_const @Num : !poly.tvar<@Ty>
      %cast = poly.unifiable_cast %num : (!poly.tvar<@Ty>) -> !felt.type<"bn128">
      %m = poly.read_const @M : !felt.type<"bn128">
      %sum = felt.add %m, %cast : !felt.type<"bn128">, !felt.type<"bn128">
      poly.yield %sum : !felt.type<"bn128">
    }
    struct.def @Value {
      function.def @compute() -> !struct.type<@Inner::@Value<[@Num, @Ty, @M]>> {
        %chosen = poly.read_const @Chosen : !felt.type<"bn128">
        %self = struct.new : <@Inner::@Value<[@Num, @Ty, @M]>>
        function.return %self : !struct.type<@Inner::@Value<[@Num, @Ty, @M]>>
      }
      function.def @constrain(%self: !struct.type<@Inner::@Value<[@Num, @Ty, @M]>>) {
        function.return
      }
    }
    function.def @value() -> !felt.type<"bn128"> {
      %chosen = poly.read_const @Chosen : !felt.type<"bn128">
      function.return %chosen : !felt.type<"bn128">
    }
  }

  poly.template @Outer {
    poly.param @Ty : !poly.tvar<@Ty>
    poly.param @M
    struct.def @Wrapper {
      struct.member @value : !struct.type<@Inner::@Value<[35, @Ty, @M]>>
      function.def @compute() -> !struct.type<@Outer::@Wrapper<[@Ty, @M]>> {
        %self = struct.new : <@Outer::@Wrapper<[@Ty, @M]>>
        function.return %self : !struct.type<@Outer::@Wrapper<[@Ty, @M]>>
      }
      function.def @constrain(%self: !struct.type<@Outer::@Wrapper<[@Ty, @M]>>) {
        function.return
      }
    }
    function.def @value() -> !felt.type<"bn128"> {
      %chosen = function.call @Inner::@value<[35, @Ty, @M]>()
        : () -> !felt.type<"bn128">
      function.return %chosen : !felt.type<"bn128">
    }
  }
}


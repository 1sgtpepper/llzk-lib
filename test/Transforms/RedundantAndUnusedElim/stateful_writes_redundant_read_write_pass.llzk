// CHECK-NEXT:    }
// CHECK-NEXT:    function.def @ram_region_boundary(%[[VAL_28:[0-9a-zA-Z_\.]+]]: index, %[[VAL_29:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_30:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_31:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_32:[0-9a-zA-Z_\.]+]]: i1) attributes {function.allow_witness} {

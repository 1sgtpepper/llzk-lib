// CHECK-NEXT:    function.def @ram_reused_load_does_not_preserve_write(%[[VAL_25:[0-9a-zA-Z_\.]+]]: index, %[[VAL_26:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_27:[0-9a-zA-Z_\.]+]]: !felt.type) -> !felt.type attributes {function.allow_witness} {

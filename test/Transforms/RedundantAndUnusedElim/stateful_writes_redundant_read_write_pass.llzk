// CHECK-NEXT:    function.def @ram_call_boundary(%[[VAL_35:[0-9a-zA-Z_\.]+]]: index, %[[VAL_36:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_37:[0-9a-zA-Z_\.]+]]: !felt.type, %[[VAL_38:[0-9a-zA-Z_\.]+]]: !felt.type) attributes {function.allow_witness} {
